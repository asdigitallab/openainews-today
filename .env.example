# --- Live deadpan rewrites (required for real headlines) ---
# Your Anthropic API key. Set in Vercel: Settings > Environment Variables.
# Without it, the site falls back to the offline signal bank.
ANTHROPIC_API_KEY=

# --- Shared, accumulating feed store (required to persist + dedupe) ---
# Create a free Upstash Redis DB (Vercel Marketplace > Upstash, or upstash.com).
# The Vercel integration sets KV_REST_API_* automatically; otherwise paste the
# UPSTASH_* values from the Upstash console. Either pair works.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional ---
# If set, the /api/cron endpoint requires this as a Bearer token. Vercel Cron
# sends it automatically when configured in the project.
CRON_SECRET=

# Override the frontend generation endpoint (defaults to /api/ingest).
# VITE_GENERATE_URL=
